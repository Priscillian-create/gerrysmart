generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum PaymentMethod {
  cash
  pos
  transfer
}

enum UserRole {
  admin
  cashier
  user
}

enum ProductStatus {
  active
  inactive
  discontinued
}

model Product {
  id           String         @id @db.VarChar(36)
  oldNumericId Int?           @map("old_numeric_id")
  barcode      String?        @db.VarChar(100)
  status       ProductStatus  @default(active)
  category     String?        @db.VarChar(100)
  expiryDate   DateTime?      @db.Date @map("expirydate")
  name         String?        @db.VarChar(255)
  price        Decimal?       @db.Decimal(10, 2)
  stock        Int?
  deleted      Boolean?       @default(false) @db.TinyInt
  deletedAt    DateTime?      @map("deletedat")
  stringId     String?        @db.VarChar(100) @map("string_id")
  updatedAt    DateTime?      @updatedAt @map("updated_at")

  @@index([category])
  @@index([status])
  @@map("products")
}

model Sale {
  id           String    @id @db.Char(36)
  receiptNumber String   @unique @db.VarChar(255) @map("receipt_number")
  total        Decimal   @default(0) @db.Decimal(10, 2)
  items        Json?
  createdAt    DateTime? @default(now()) @db.Timestamp(0) @map("created_at")
  updatedAt    DateTime? @updatedAt @db.Timestamp(0) @map("updated_at")
  deletedAt    DateTime? @db.Timestamp(0) @map("deleted_at")
  clientSaleId String?   @db.VarChar(255) @map("client_sale_id")

  @@index([createdAt])
  @@index([deletedAt])
  @@map("sales")
}

model Expense {
  id          String   @id @default(uuid()) @db.Char(36)
  description String   @db.VarChar(191)
  category    String   @db.VarChar(100)
  amount      Decimal  @db.Decimal(12, 2)
  date        DateTime
  createdAt   DateTime @default(now())

  @@index([category])
  @@index([date])
  @@map("expenses")
}

model Purchase {
  id              Int       @id @default(autoincrement())
  date            DateTime  @db.Date
  supplier        String    @db.VarChar(255)
  productLegacyId Int?      @map("product_id")
  productName     String    @db.VarChar(255) @map("product_name")
  quantity        Int       @default(1)
  costPrice       Decimal   @default(0) @db.Decimal(10, 2) @map("cost_price")
  sellingPrice    Decimal?  @db.Decimal(10, 2) @map("selling_price")
  description     String?
  invoiceNumber   String?   @db.VarChar(100) @map("invoice_number")
  notes           String?
  createdAt       DateTime? @default(now()) @db.Timestamp(0) @map("created_at")

  @@index([date])
  @@index([createdAt])
  @@map("purchases")
}

model User {
  id       Int       @id @default(autoincrement())
  name     String?   @db.VarChar(100)
  email    String?   @unique @db.VarChar(100)
  password String?   @db.VarChar(255)
  role     UserRole? @default(user)

  @@map("users")
}
