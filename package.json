{
  "name": "gerrysmart-main",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "set NEXT_DIST_DIR=.next-build&& node scripts/clean-next.cjs && next build",
    "start": "set NEXT_DIST_DIR=.next-build&& next start",
    "lint": "set ESLINT_USE_FLAT_CONFIG=false&& next lint",
    "postinstall": "node scripts/postinstall.cjs",
    "prisma:generate": "node scripts/run-prisma.cjs generate",
    "prisma:push": "node scripts/run-prisma.cjs db push",
    "prisma:seed": "node prisma/seed.js"
  },
  "prisma": {
    "seed": "node prisma/seed.js"
  },
  "dependencies": {
    "@prisma/client": "^6.7.0",
    "@swc/helpers": "0.5.15",
    "bcryptjs": "^2.4.3",
    "dotenv": "^17.4.1",
    "jose": "^5.9.6",
    "mysql2": "^3.22.0",
    "next": "16.2.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/next": "^8.0.7",
    "@types/node": "^22.14.0",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "eslint": "^9.23.0",
    "eslint-config-next": "16.2.4",
    "prisma": "^6.7.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.3"
  }
}
